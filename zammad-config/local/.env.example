# Credentials for the local Zammad instance.
# Copy to .env: cp .env.example .env
# .env is gitignored — never commit real values.
#
# ZAMMAD_URL and ZAMMAD_TOKEN are written automatically by:
#   pnpm run zammad:local:setup
#
# You only need to set these manually if you want to run configure/export
# scripts against local without running the full setup.

ZAMMAD_URL=http://localhost:3001
ZAMMAD_TOKEN=
