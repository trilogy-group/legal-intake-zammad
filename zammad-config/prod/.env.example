# Credentials for the production Zammad instance.
# Copy to .env: cp .env.example .env
# .env is gitignored — never commit real values.
#
# Get these from the production Zammad admin:
#   Profile → Token Access → Create token with "admin" permission

ZAMMAD_URL=https://your-prod-zammad.example.com
ZAMMAD_TOKEN=your_prod_admin_api_token
