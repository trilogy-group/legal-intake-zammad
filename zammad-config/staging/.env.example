# Credentials for the staging Zammad instance.
# Copy to .env: cp .env.example .env
# .env is gitignored — never commit real values.
#
# Get these from the staging Zammad admin:
#   Profile → Token Access → Create token with "admin" permission

ZAMMAD_URL=https://your-staging-zammad.example.com
ZAMMAD_TOKEN=your_staging_admin_api_token
