<div class="settings-entry">
  <p><%- @T(@description) %></p>

  <div>
    <button type="button" class="btn btn--action js-downloadFeedback">
      <%- @Icon('download') %>
      <span><%- @T('Download Feedback') %></span>
    </button>
    <button type="button" class="btn btn--action js-downloadErrorLogs">
      <%- @Icon('download') %>
      <span><%- @T('Download Error Logs') %></span>
    </button>
  </div>

  <div class="js-log"></div>
</div>
