<div class="settings-entry">
  <p><%- @T(@description) %></p>

  <div>
    <button type="button" class="btn btn--primary js-downloadFeedback">
      <%- @T('Download Feedback') %>
    </button>
    <button type="button" class="btn btn--danger js-downloadErrorLogs">
      <%- @T('Download Error Logs') %>
    </button>
  </div>

  <div class="js-log"></div>
</div>
