Osvežen tiket (#{ticket.title})

<div>Zdravo #{recipient.firstname},</div>
<br>
<div>
Tiket (#{ticket.title}) je osvežen od strane „<b>#{current_user.longname}</b>”.
</div>
<br>
<% if @objects[:changes].present? %>
  <div>
  Promene:<br>
  <% @objects[:changes].each do |key, value| %>
    <%= t key %>: <%= h value[0] %> -&gt; <%= h value[1] %><br>
  <% end %>
  </div>
<% end %>
<br>

<br>
<div>
  <a href="#{config.http_type}://#{config.fqdn}/#ticket/zoom/#{ticket.id}" target="zammad_app">Pogledaj u #{config.product_name}</a>
</div>
