Aktualisiertes Ticket (#{ticket.title})

<div>Hallo #{recipient.fullname},</div>
<br>
<div>
das Ticket (#{ticket.title}) wurde von "<b>#{current_user.longname}</b>" aktualisiert.
</div>
<br>
<% if @objects[:changes].present? %>
  <div>
  Änderungen:<br>
  <% @objects[:changes].each do |key, value| %>
    <%= t key %>: <%= h value[0] %> -&gt; <%= h value[1] %><br>
  <% end %>
  </div>
<% end %>
<br>

<br>
<div>
  <a href="#{config.http_type}://#{config.fqdn}/#ticket/zoom/#{ticket.id}" target="zammad_app">In #{config.product_name} anzeigen</a>
</div>
