Internal Note: #{ticket.title}

<div style="font-family: sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
  <div style="text-align: center; margin-bottom: 32px;">
    <h1 style="font-size: 24px; font-weight: bold; color: #1f2937; margin: 0;">Legal Intake</h1>
  </div>
  
  <p style="font-size: 16px;">Hello #{recipient.firstname},</p>
  
  <p style="font-size: 16px;">
    #{commenter.firstname} #{commenter.lastname} added an internal note to ticket "<strong>#{ticket.title}</strong>".
  </p>
  
  <% if @objects[:article] && @objects[:article].body.present? %>
  <div style="background-color: #fef3c7; border-left: 4px solid #f59e0b; padding: 16px; margin: 20px 0; border-radius: 4px;">
    <p style="font-size: 14px; font-weight: 600; margin: 0 0 8px 0; color: #92400e;">
      Internal Note:
    </p>
    <p style="font-size: 14px; color: #78350f; margin: 0 0 8px 0; line-height: 1.5;">
      <strong style="color: #f59e0b;">#{commenter.firstname} #{commenter.lastname} wrote:</strong><br/>
      <%= HtmlSanitizer.dynamic_image_size(@objects[:article].body_as_html).html_safe %>
    </p>
    <% if @objects[:article].attachments.any? %>
    <p style="font-size: 12px; line-height: 24px; color: #b45309; margin: 8px 0 0 0; font-weight: 500;">
      📎 <%= @objects[:article].attachments.count %> attachment<% if @objects[:article].attachments.count != 1 %>s<% end %>
    </p>
    <% end %>
  </div>
  <% end %>
  
  <p style="font-size: 14px; color: #6b7280; font-style: italic;">
    Note: This is an internal note visible only to agents and not visible to customers.
  </p>
  
  <div style="text-align: center; margin: 32px 0;">
    <a href="#{config.http_type}://#{config.fqdn}/#ticket/zoom/#{ticket.id}" 
       style="background-color: #f59e0b; color: #ffffff; padding: 12px 24px; border-radius: 6px; text-decoration: none; font-weight: 500; display: inline-block;">
      View Ticket
    </a>
  </div>
  
  <p style="font-size: 14px; color: #6b7280;">
    If you're unable to click the button above, you can copy and paste this link:<br/>
    <a href="#{config.http_type}://#{config.fqdn}/#ticket/zoom/#{ticket.id}">#{config.http_type}://#{config.fqdn}/#ticket/zoom/#{ticket.id}</a>
  </p>
  
  <p style="font-size: 12px; color: #6b7280; margin-top: 32px;">
    You are receiving this because you are a member of the group of this ticket.
  </p>
</div>
