Internal Note: #{ticket.title}

<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional//EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html dir="ltr" lang="en">
  <head>
    <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
    <meta name="x-apple-disable-message-reformatting" />
  </head>
  <body style="background-color:#ffffff;font-family:sans-serif">
    <div style="display:none;overflow:hidden;line-height:1px;opacity:0;max-height:0;max-width:0" data-skip-in-text="true">
      #{commenter.firstname} #{commenter.lastname} added an internal note to #{ticket.title}
      <div>
         вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ вАМвАЛвАНвАОвАПпїњ
      </div>
    </div>
    
    <table align="center" width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation" style="max-width:600px;margin:0 auto;padding:20px">
      <tbody>
        <tr style="width:100%">
          <td>
            <table align="center" width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation" style="text-align:center;margin-bottom:32px">
              <tbody>
                <tr>
                  <td>
                    <p style="font-size:24px;line-height:24px;font-weight:bold;color:#1f2937;margin:0">
                      Legal Intake
                    </p>
                  </td>
                </tr>
              </tbody>
            </table>
            
            <p style="font-size:16px;line-height:24px;margin-top:16px;margin-bottom:16px">
              Hello #{recipient.firstname},
            </p>
            
            <p style="font-size:16px;line-height:24px;margin-top:16px;margin-bottom:16px">
              #{commenter.firstname} #{commenter.lastname} added an internal note to ticket "<strong>#{ticket.title}</strong>".
            </p>
            
            <% if article && article.body.present? %>
            <div style="background-color:#fef3c7;border-left:4px solid #f59e0b;padding:16px;margin:20px 0;border-radius:4px">
              <p style="font-size:14px;font-weight:600;margin:0 0 8px 0;color:#92400e">
                Internal Note:
              </p>
              <p style="font-size:14px;color:#78350f;margin:0 0 8px 0;line-height:1.5">
                <strong style="color:#f59e0b">#{commenter.firstname} #{commenter.lastname} wrote:</strong><br/>
                <%= HtmlSanitizer.dynamic_image_size(article.body_as_html).html_safe %>
              </p>
              <% if article.attachments.any? %>
              <p style="font-size:12px;line-height:24px;color:#b45309;margin:8px 0 0 0;font-weight:500">
                рЯУО #{article.attachments.count} attachment<% if article.attachments.count != 1 %>s<% end %>
              </p>
              <% end %>
            </div>
            <% end %>
            
            <p style="font-size:14px;line-height:24px;color:#6b7280;margin-top:16px;margin-bottom:16px;font-style:italic">
              Note: This is an internal note visible only to agents and not visible to customers.
            </p>
            
            <table align="center" width="100%" border="0" cellpadding="0" cellspacing="0" role="presentation" style="text-align:center;margin:32px 0">
              <tbody>
                <tr>
                  <td>
                    <a href="#{config.http_type}://#{config.fqdn}/#ticket/zoom/#{ticket.id}" style="line-height:100%;text-decoration:none;display:inline-block;max-width:100%;background-color:#f59e0b;color:#ffffff;padding:12px 24px;border-radius:6px;font-weight:500" target="_blank">
                      View Ticket
                    </a>
                  </td>
                </tr>
              </tbody>
            </table>
            
            <p style="font-size:14px;line-height:24px;color:#6b7280;margin-top:16px;margin-bottom:16px">
              If you're unable to click the button above, you can copy and paste this link:
            </p>
            
            <p style="font-size:14px;line-height:24px;word-break:break-all;margin-top:16px;margin-bottom:16px">
              <a href="#{config.http_type}://#{config.fqdn}/#ticket/zoom/#{ticket.id}" style="color:#067df7;text-decoration-line:none" target="_blank">
                #{config.http_type}://#{config.fqdn}/#ticket/zoom/#{ticket.id}
              </a>
            </p>
            
            <p style="font-size:12px;line-height:20px;color:#6b7280;margin-top:32px;margin-bottom:0">
              You are receiving this because you are a member of the group of this ticket.
            </p>
          </td>
        </tr>
      </tbody>
    </table>
  </body>
</html>
