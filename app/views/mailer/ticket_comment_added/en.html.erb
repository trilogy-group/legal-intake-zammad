<div style="font-family: sans-serif; max-width: 600px; margin: 0 auto; padding: 20px;">
  <div style="text-align: center; margin-bottom: 32px;">
    <h1 style="font-size: 24px; font-weight: bold; color: #1f2937; margin: 0;">Legal Intake</h1>
  </div>
  
  <p style="font-size: 16px;">Hello <%= d 'recipient.firstname' %>,</p>
  
  <p style="font-size: 16px;">
    A new comment has been added to your ticket "<strong><%= d 'ticket.title' %></strong>".
  </p>
  
  <div style="background-color: #EBF4FF; border: 1px solid #3D99F5; border-radius: 8px; padding: 16px; margin: 24px 0;">
    <p style="font-size: 14px; color: #1f2937; margin: 0; line-height: 1.5;">
      <strong style="color: #3D99F5;"><%= d 'article.created_by.firstname' %> <%= d 'article.created_by.lastname' %> commented:</strong><br/>
      <%= c 'article.body', 150 %>
    </p>
  </div>
  
  <p style="font-size: 16px;">
    You're receiving this notification because <%= c 'reason' %>. Join the discussion to stay updated on the latest developments.
  </p>
  
  <div style="text-align: center; margin: 32px 0;">
    <a href="<%= c 'config.http_type' %>://<%= c 'config.fqdn' %>/#ticket/zoom/<%= c 'ticket.id' %>" 
       style="background-color: #3D99F5; color: #ffffff; padding: 12px 24px; border-radius: 6px; text-decoration: none; font-weight: 500; display: inline-block;">
      View Discussion
    </a>
  </div>
  
  <p style="font-size: 14px; color: #6b7280;">
    If you're unable to click the button above, you can copy and paste this link:<br/>
    <a href="<%= c 'config.http_type' %>://<%= c 'config.fqdn' %>/#ticket/zoom/<%= c 'ticket.id' %>"><%= c 'config.http_type' %>://<%= c 'config.fqdn' %>/#ticket/zoom/<%= c 'ticket.id' %></a>
  </p>
</div>
