<title><%= @context_data[:ticket].title %></title>
<% @context_data[:ticket].articles.without_system_notifications.each do |article| -%>
  <% next if article.body.blank? -%>
  <% next if article.body_as_text.blank? -%>
  <% if article.type.name == 'email' -%>
    <% result = Text::QuoteRemover
               .new(text: article.body_as_text(link_style: :markdown))
               .remove %>
    <% next if result.blank? %>
  <% else -%>
    <% result = article.body_as_text %>
  <% end -%>
<article>
  <sender_type><%= article.sender.name %></sender_type>
  <sender_name><%= article.author.fullname %></sender_name>
  <created_at><%= article.created_at %></created_at>
  <visibility><%= article.internal ? 'internal' : 'public' %></visibility>
  <text><%= result %></text>
</article>
<% end -%>
