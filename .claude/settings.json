{
  "permissions": {
    "allow": [
      "Bash(git log *)",
      "Bash(git show *)",
      "Bash(git diff *)",
      "Bash(git blame *)",
      "Bash(git branch *)",
      "Bash(git status *)",
      "Bash(ls *)",
      "Bash(bundle exec rubocop *)",
      "Bash(RAILS_ENV=test VITE_TEST_MODE=1 bundle exec rspec *)",
      "Bash(pnpm test *)",
      "Bash(pnpm lint *)",
      "Bash(pnpm generate-graphql-api)",
      "Bash(pnpm generate-setting-types)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/lint-after-edit.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
