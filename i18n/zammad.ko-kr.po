msgstr "애플리케이션의 임의 시크릿을 정의합니다."

#: db/seeds/settings.rb:4492
msgid "Defines the sender email address of Icinga emails."
msgstr "Icinga 이메일에 사용할 발신 주소를 정의합니다."

#: db/seeds/settings.rb:4590
msgid "Defines the sender email address of Nagios emails."
msgstr "Nagios 이메일에 사용할 발신 주소를 정의합니다."

#: db/seeds/settings.rb:4688
