"<br>\n"
"<% if @objects[:article] %>\n"
"  <div>\n"
"  Information:\n"
"  <blockquote type=\"cite\">\n"
"  #{article.body_as_html}\n"
"  </blockquote>\n"
"  </div>\n"
"<% end %>\n"
"<br>\n"
"<div>\n"
"  <a href=\"#{config.http_type}://#{config.fqdn}/#ticket/zoom/#{ticket.id}\" "
"target=\"zammad_app\">View this in #{config.product_name}</a>\n"
"</div>\n"
msgstr ""
"Tiket dieskalasi (#{ticket.title})\r\n"
"\r\n"
"<div>Hai #{recipient.firstname},</div>\r\n"
"<br>\r\n"
"<div>Ticket (#{ticket.title}) dari \"<b>#{ticket.customer.longname}</b>\" "
"telah dieskalasi pada \"#{ticket.escalation_at}\"!</div>\r\n"
"<br>\r\n"
"<% if @objects[:article] %>\r\n"
"  <div>\r\n"
"Informasi:\r\n"
"  <blockquote type=\"cite\">\r\n"
"  #{article.body_as_html}\r\n"
"  </blockquote>\r\n"
"  </div>\r\n"
"<% end %>\r\n"
"<br>\r\n"
"<div>\r\n"
"  <a href=\"#{config.http_type}://#{config.fqdn}/#ticket/zoom/#{ticket.id}\" "
"target=\"zammad_app\">Lihat Pada #{config.product_name}</a>\r\n"
"</div>\n"

