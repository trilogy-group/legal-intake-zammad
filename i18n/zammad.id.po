#: app/views/mailer/password_reset/en.html.erb
msgid ""
"Reset your #{config.product_name} password\n"
"\n"
"<div>Hi #{user.firstname},</div>\n"
"<br>\n"
"<div>We received a request to reset the password for your "
"#{config.product_name} account <b>#{user.login}</b>.</div>\n"
"<br>\n"
"<div>If you want to reset your password, click on the link below (or copy "
"and paste the URL into your browser):</div>\n"
"<br>\n"
"<div><a href=\"#{url}\">#{url}</a></div>\n"
"<br>\n"
"<div>This link takes you to a page where you can change your password.</"
"div>\n"
"<br>\n"
"<div>If you don't want to reset your password, please ignore this message. "
"Your password will not be reset.</div>\n"
"<br>\n"
"<div>Your #{config.product_name} Team</div>\n"
msgstr ""
"Reset kata sandi #{config.product_name} Anda\n"
"\n"
"<div>Hai #{user.firstname},</div>\n"
"<br>\n"
"<div>Kami menerima permintaan untuk mereset kata sandi untuk akun "
"#{config.product_name} Anda <b>#{user.login}</b>.</div>\n"
"<br>\n"
"<div>Jika Anda ingin mereset kata sandi Anda, klik tautan di bawah ini (atau "
"salin dan tempel URL ke browser Anda):</div>\n"
"<br>\n"
"<div><a href=\"#{url}\">#{url}</a></div>\n"
"<br>\n"
"<div>Tautan ini membawa Anda ke halaman di mana Anda dapat mengubah kata "
"sandi Anda.</div>\n"
"<br>\n"
"<div>Jika Anda tidak ingin mereset kata sandi Anda, abaikan pesan ini. Kata "
"sandi Anda tidak akan direset.</div>\n"
"<br>\n"
"<div>Tim #{config.product_name} Anda</div>\n"

