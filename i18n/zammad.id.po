msgstr "Mendefinisikan alamat email pengirim email Icinga."

#: db/seeds/settings.rb:4590
msgid "Defines the sender email address of Nagios emails."
msgstr "Mendefinisikan alamat email pengirim email Nagios."

#: db/seeds/settings.rb:4688
msgid "Defines the sender email address of the service emails."
msgstr "Mendefinisikan alamat email pengirim email layanan."

#: db/seeds/settings.rb:3430
msgid "Defines the sender of email notifications."
msgstr "Mendefinisikan pengirim notifikasi email."

