msgstr ""
"Mendefinisikan jangka waktu di mana catatan yang dibuat sendiri dapat "
"dihapus."

#: db/seeds/settings.rb:5327
msgid "Defines the token for Placetel."
msgstr "Mendefinisikan token untuk Placetel."

