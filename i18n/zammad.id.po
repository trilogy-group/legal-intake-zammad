msgid "Defines the default calendar tickets subscription settings."
msgstr "Mendefinisikan pengaturan langganan tiket kalender default."

#: db/seeds/settings.rb:3609
msgid "Defines the default screen."
msgstr "Mendefinisikan layar default."

#: db/seeds/settings.rb:167
