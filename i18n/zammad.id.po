#: db/seeds/settings.rb:5176
msgid "Defines the sipgate.io config."
msgstr "Mendefinisikan konfigurasi sipgate.io."

#: db/seeds/settings.rb:4541
msgid "Defines the state of auto-closed tickets."
msgstr "Mendefinisikan status tiket yang ditutup otomatis."

#: db/seeds/settings.rb:265
msgid ""
"Defines the system identifier. Every ticket number contains this ID. This "
"ensures that only tickets which belong to your system will be processed as "
"follow-ups (useful when communicating between two instances of Zammad)."
msgstr ""
"Mendefinisikan pengidentifikasi sistem. Setiap nomor tiket berisi ID ini. "
"Ini memastikan bahwa hanya tiket yang milik sistem Anda akan diproses "
"sebagai tindak lanjut (berguna saat berkomunikasi antara dua instance "
"Zammad)."

#: db/seeds/settings.rb:3005
msgid "Defines the tab behaviour after a ticket action."
msgstr "Mendefinisikan perilaku tab setelah tindakan tiket."

#: db/seeds/settings.rb:2800
msgid "Defines the ticket states used for lookups."
msgstr "Mendefinisikan status tiket yang digunakan untuk pencarian."

#: db/seeds/settings.rb:5571
