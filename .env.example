# Native Rails environment for legal-intake-zammad.
# Copy to .env: cp .env.example .env  (.env is gitignored)
#
# Prerequisites: pnpm run zammad:local:up  (starts infra Docker containers)

# ── Rails ─────────────────────────────────────────────────────────────────────
RAILS_ENV=development

# Matches legal-intake's ZAMMAD_URL=http://localhost:3001
ZAMMAD_RAILS_PORT=3001

# ── Database ──────────────────────────────────────────────────────────────────
# Points to the Postgres container started by pnpm run zammad:local:up
# (mapped to host port 5433 to avoid conflicts with native Postgres on 5432)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5433/zammad

# ── Elasticsearch ─────────────────────────────────────────────────────────────
ELASTICSEARCH_ENABLED=true
ELASTICSEARCH_SCHEMA=http
ELASTICSEARCH_HOST=localhost
ELASTICSEARCH_PORT=9200

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Memcached ─────────────────────────────────────────────────────────────────
MEMCACHE_SERVERS=localhost:11211

# ── Email (silently dropped in dev) ───────────────────────────────────────────
ZAMMAD_SENDMAIL_LOCATION=/usr/bin/true
