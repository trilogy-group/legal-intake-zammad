# Local Zammad environment configuration.
# Copy this file to .env: cp .env.example .env
# The .env file is gitignored.

# ── Admin credentials ─────────────────────────────────────────────────────────
# Used by setup.sh to create the admin user on first run and to authenticate.
# Use these to log in to the Zammad UI at http://localhost:3001
# Set these in your .env — do not commit real values here.
ZAMMAD_LOCAL_ADMIN_LOGIN=
ZAMMAD_LOCAL_ADMIN_PASSWORD=

# ── Bot user credentials ──────────────────────────────────────────────────────
# The legal-agent-bot service account used by the legal-intake app.
ZAMMAD_LOCAL_BOT_LOGIN=
ZAMMAD_LOCAL_BOT_PASSWORD=

# ── Zammad API (written by setup.sh) ─────────────────────────────────────────
# These are populated automatically by npm run zammad:local:setup.
# You can also set them manually after logging in as admin and creating an API
# token under Admin → Integrations → API.
ZAMMAD_URL=http://localhost:3001
ZAMMAD_TOKEN=
